!# Gamebian-installed — monochrome dark window decorations (matches gtk-3.0/gamebian-installed)

*.font: shadow=n
window.active.label.text.font:shadow=y:shadowtint=20:shadowoffset=1
window.inactive.label.text.font:shadow=y:shadowtint=00:shadowoffset=0
menu.items.font:shadow=y:shadowtint=0:shadowoffset=1

border.width: 1
padding.width: 3
padding.height: 2
window.handle.width: 3
window.client.padding.width: 0
menu.overlap: 2
*.justify: center

*.bg.highlight: 40
*.bg.shadow: 05

window.active.title.bg.highlight: 30
window.active.title.bg.shadow: 05

window.inactive.title.bg.highlight: 25
window.inactive.title.bg.shadow: 05

window.*.grip.bg.highlight: 40
window.*.grip.bg.shadow: 25

window.*.handle.bg.highlight: 40
window.*.handle.bg.shadow: 25

menu.border.color: #000000
menu.border.width: 1

menu.title.bg: solid flat
menu.title.bg.color: #1a1a1a
menu.title.text.color: #ffffff

menu.items.bg: Flat Solid
menu.items.bg.color: #151515
menu.items.text.color: #eaeaea
menu.items.disabled.text.color: #777777

menu.items.active.bg: Flat Solid border
menu.items.active.bg.color: #333333
menu.items.active.bg.border.color: #000000
menu.items.active.text.color: #ffffff

menu.separator.width: 1
menu.separator.padding.width: 0
menu.separator.padding.height: 3
menu.separator.color: #333333

window.*.handle.bg: Raised solid
window.*.handle.bg.color: #121212

window.*.grip.bg: Raised solid
window.*.grip.bg.color: #121212

window.*.border.color: #000000

window.active.title.separator.color: #2a2a2a

*.title.bg: Raised Gradient splitvertical
*.title.bg.color: #282828
*.title.bg.color.splitTo: #1a1a1a
*.title.bg.colorTo: #171717
*.title.bg.colorTo.splitTo: #0d0d0d

window.active.label.bg: Parentrelative
window.active.label.text.color: #ffffff

window.active.button.*.bg: Flat Gradient splitvertical Border
window.active.button.*.bg.color: #303030
window.active.button.*.bg.color.splitTo: #232323
window.active.button.*.bg.colorTo: #1c1c1c
window.active.button.*.bg.colorTo.splitTo: #141414
window.active.button.*.bg.border.color: #000000
window.active.button.*.image.color: #e8e8e8

window.active.button.hover.bg.color: #383838
window.active.button.hover.bg.color.splitTo: #383838
window.active.button.hover.bg.colorTo: #2c2c2c
window.active.button.hover.bg.colorTo.splitTo: #252525
window.active.button.hover.bg.border.color: #ffffff
window.active.button.hover.image.color: #ffffff

window.active.button.pressed.bg: Flat solid Border
window.active.button.pressed.bg.color: #1a1a1a

window.inactive.title.separator.color: #3a3a3a

window.inactive.title.bg: Raised Gradient splitvertical
window.inactive.title.bg.color: #3d3d3d
window.inactive.title.bg.color.splitTo: #353535
window.inactive.title.bg.colorTo: #2e2e2e
window.inactive.title.bg.colorTo.splitTo: #262626

window.inactive.label.bg: Parentrelative
window.inactive.label.text.color: #b0b0b0

window.inactive.button.*.bg: Flat Gradient splitVertical Border
window.inactive.button.*.bg.color: #393939
window.inactive.button.*.bg.color.splitto: #313131
window.inactive.button.*.bg.colorTo: #2a2a2a
window.inactive.button.*.bg.colorTo.splitto: #222222
window.inactive.button.*.bg.border.color: #1a1a1a
window.inactive.button.*.image.color: #909090

osd.border.width: 1
osd.border.color: #000000

osd.bg: flat border gradient splitvertical
osd.bg.color: #151515
osd.bg.color.splitto: #202020
osd.bg.colorTo: #151515
osd.bg.colorTo.splitto: #0a0a0a

osd.bg.border.color: #333333

osd.active.label.bg: parentrelative
osd.active.label.text.color: #ffffff

osd.inactive.label.bg: parentrelative
osd.inactive.label.text.color: #a8a8a8

osd.hilight.bg: flat vertical gradient
osd.hilight.bg.color: #383838
osd.hilight.bg.colorTo: #202020
osd.unhilight.bg: flat vertical gradient
osd.unhilight.bg.color: #454545
osd.unhilight.bg.colorTo: #303030
