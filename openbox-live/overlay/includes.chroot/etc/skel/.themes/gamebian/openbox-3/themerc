!# Gamebian — Openbox 3 theme (Calamares branding colors)
!# SidebarBackground #0145F2, SidebarText #FFFFFF
!# SidebarTextCurrent #F9F8F4, SidebarBackgroundCurrent #056EDB
!# Derived layout from Debian Clearlooks openbox theme.

*.font: shadow=n
window.active.label.text.font:shadow=y:shadowtint=30:shadowoffset=1
window.inactive.label.text.font:shadow=y:shadowtint=00:shadowoffset=0
menu.items.font:shadow=y:shadowtint=0:shadowoffset=1

border.width: 1
padding.width: 3
padding.height: 2
window.handle.width: 3
window.client.padding.width: 0
menu.overlap: 2
*.justify: center

*.bg.highlight: 50
*.bg.shadow: 05

window.active.title.bg.highlight: 35
window.active.title.bg.shadow: 05

window.inactive.title.bg.highlight: 30
window.inactive.title.bg.shadow: 05

window.*.grip.bg.highlight: 50
window.*.grip.bg.shadow: 30

window.*.handle.bg.highlight: 50
window.*.handle.bg.shadow: 30

menu.border.color: #0238C9
menu.border.width: 1

menu.title.bg: solid flat
menu.title.bg.color: #056EDB
menu.title.text.color: #FFFFFF

menu.items.bg: Flat Solid
menu.items.bg.color: #0145F2
menu.items.text.color: #FFFFFF
menu.items.disabled.text.color: #9EB4F0

menu.items.active.bg: Flat Solid border
menu.items.active.bg.color: #056EDB
menu.items.active.bg.border.color: #0341D6
menu.items.active.text.color: #F9F8F4

menu.separator.width: 1
menu.separator.padding.width: 0
menu.separator.padding.height: 3
menu.separator.color: #0238C9

window.*.handle.bg: Raised solid
window.*.handle.bg.color: #0145F2

window.*.grip.bg: Raised solid
window.*.grip.bg.color: #0145F2

window.*.border.color: #0238C9

window.active.title.separator.color: #056EDB

*.title.bg: Raised Gradient splitvertical
*.title.bg.color: #056EDB
*.title.bg.color.splitTo: #0145F2
*.title.bg.colorTo: #0145F2
*.title.bg.colorTo.splitTo: #0238C9

window.active.label.bg: Parentrelative
window.active.label.text.color: #FFFFFF

window.active.button.*.bg: Flat Gradient splitvertical Border
window.active.button.*.bg.color: #056EDB
window.active.button.*.bg.color.splitTo: #0145F2
window.active.button.*.bg.colorTo: #0145F2
window.active.button.*.bg.colorTo.splitTo: #0238C9
window.active.button.*.bg.border.color: #0238C9
window.active.button.*.image.color: #F9F8F4

window.active.button.hover.bg.color: #056EDB
window.active.button.hover.bg.color.splitTo: #056EDB
window.active.button.hover.bg.colorTo: #0145F2
window.active.button.hover.bg.colorTo.splitTo: #0145F2
window.active.button.hover.bg.border.color: #FFFFFF
window.active.button.hover.image.color: #FFFFFF

window.active.button.pressed.bg: Flat solid Border
window.active.button.pressed.bg.color: #0238C9

window.inactive.title.separator.color: #4A5FA8

window.inactive.title.bg: Raised Gradient splitvertical
window.inactive.title.bg.color: #2D4AA8
window.inactive.title.bg.color.splitTo: #1E3A8A
window.inactive.title.bg.colorTo: #1E3A8A
window.inactive.title.bg.colorTo.splitTo: #152E70

window.inactive.label.bg: Parentrelative
window.inactive.label.text.color: #C8D4F5

window.inactive.button.*.bg: Flat Gradient splitVertical Border
window.inactive.button.*.bg.color: #2D4AA8
window.inactive.button.*.bg.color.splitto: #1E3A8A
window.inactive.button.*.bg.colorTo: #1E3A8A
window.inactive.button.*.bg.colorTo.splitto: #152E70
window.inactive.button.*.bg.border.color: #152E70
window.inactive.button.*.image.color: #9EB4F0

osd.border.width: 1
osd.border.color: #0238C9

osd.bg: flat border gradient splitvertical
osd.bg.color: #0145F2
osd.bg.color.splitto: #056EDB
osd.bg.colorTo: #0145F2
osd.bg.colorTo.splitto: #0238C9

osd.bg.border.color: #056EDB

osd.active.label.bg: parentrelative
osd.active.label.text.color: #FFFFFF

osd.inactive.label.bg: parentrelative
osd.inactive.label.text.color: #C8D4F5

osd.hilight.bg: flat vertical gradient
osd.hilight.bg.color: #056EDB
osd.hilight.bg.colorTo: #0145F2
osd.unhilight.bg: flat vertical gradient
osd.unhilight.bg.color: #2D4AA8
osd.unhilight.bg.colorTo: #1E3A8A
