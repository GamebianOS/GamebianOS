#!/bin/sh
set -e
chmod 0755 /usr/local/bin/gamebian-controller-menu 2>/dev/null || true
chmod 0755 /usr/share/gamebian/gamebian-lxpanel-tray.sh 2>/dev/null || true
chmod 0755 /usr/local/sbin/gamebian-ensure-apt-sources 2>/dev/null || true
chmod 0755 /usr/sbin/gamebian-enter-steam-kiosk-session 2>/dev/null || true
chmod 0644 /usr/share/gamebian/gamebian-lightdm-user.sh 2>/dev/null || true
chmod 0644 /usr/share/gamebian/gamebian_controller_menu.py 2>/dev/null || true
# Live session user: read /dev/input/event* when logind uaccess is not enough
if getent passwd live >/dev/null 2>&1; then
	usermod -aG input live 2>/dev/null || true
fi
