# Minimal boot / admin / connectivity (beyond the graphical stack)
sudo
systemd-sysv
linux-image-amd64
network-manager
# Tray: nm-tray (Qt); blueman-applet (GTK) for Bluetooth — start after lxpanel systray in autostart
nm-tray
bluez
blueman
qt5-gtk-platformtheme
qt6-gtk-platformtheme
hicolor-icon-theme
libqt5svg5
# Standalone NM connection GUI (pairs with nm-tray — do not rely on applet metapackages)
nm-connection-editor
# Graphical PolKit agent: without it, Wi‑Fi / NM prompts may not accept keyboard input under Openbox.
# PolKit GUI agent (policykit-1-gnome removed from Trixie — mate-polkit provides GTK prompts for NM, etc.)
mate-polkit
# Secret service + PAM unlock: NM / nm-tray store Wi‑Fi PSKs reliably (avoids broken passphrase prompts).
gnome-keyring
libpam-gnome-keyring
iproute2
openssh-client
openssh-server
vim

# Icon themes (Papirus is default in skel GTK settings; others available in lxappearance)
adwaita-icon-theme
adwaita-icon-theme-legacy
mint-y-icons
numix-icon-theme-circle
paper-icon-theme
papirus-icon-theme
yaru-theme-icon

# Display manager + Openbox session (exact Gamebian desktop stack)
lightdm
lightdm-gtk-greeter
desktop-base

openbox
python3
python3-evdev
python3-tk
lxappearance
lxappearance-obconf
# X11 resolution / monitor mode picker (RandR); pairs with Openbox on Gamebian.
lxrandr
lxpanel
rofi
feh
thunar
xfce4-terminal
# GNOME Web (WebKitGTK); chroot hook sets x-www-browser alternative.
epiphany-browser
# Audio mixer GUI (outputs, per-app levels); works with PipeWire via Pulse compatibility.
pavucontrol

# Steam: Debian testing/stable use steam-installer (+ steam-libs, steam-libs-i386), not Valve’s steam-launcher.
# i386: includes.chroot_before_packages/root/packages.foreign-architectures (live-build runs dpkg --add-architecture).
steam-installer
steam-devices
# Nested Big Picture session under Openbox (/usr/local/bin/gamebian-steam-bigpicture uses gamescope -e).
gamescope

# Installer (removed from disk install via Calamares packages module + autoremove)
calamares
calamares-settings-debian
qml-module-qtquick-controls2
