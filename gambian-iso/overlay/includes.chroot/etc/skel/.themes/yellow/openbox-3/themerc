!# yellow — Openbox 3 (#f2ae01)

*.font: shadow=n
window.active.label.text.font: shadow=n
window.inactive.label.text.font: shadow=n
menu.items.font: shadow=n

border.width: 1
padding.width: 4
padding.height: 3
window.handle.width: 2
window.client.padding.width: 0
menu.overlap: 2
*.justify: left

window.active.border.color: #bdbdbd
window.inactive.border.color: #bdbdbd
window.active.client.color: #fafafa
window.inactive.client.color: #fafafa

window.active.title.separator.color: #bdbdbd
window.inactive.title.separator.color: #bdbdbd

window.active.label.text.color: #1e1e1e
window.inactive.label.text.color: #777777

window.active.title.bg: flat solid
window.active.title.bg.color: #ebebeb
window.active.label.bg: parentrelative
window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #ebebeb
window.inactive.label.bg: parentrelative

window.active.handle.bg: flat solid
window.active.handle.bg.color: #ebebeb
window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #ebebeb
window.active.grip.bg: flat solid
window.active.grip.bg.color: #ebebeb
window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #ebebeb

window.active.button.unpressed.bg: parentrelative
window.active.button.unpressed.image.color: #1e1e1e
window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #d8d8d8
window.active.button.hover.image.color: #1e1e1e
window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #f2ae01
window.active.button.pressed.image.color: #ffffff
window.active.button.disabled.bg: parentrelative
window.active.button.disabled.image.color: #777777

window.inactive.button.unpressed.bg: parentrelative
window.inactive.button.unpressed.image.color: #777777
window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #d8d8d8
window.inactive.button.hover.image.color: #1e1e1e
window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #f2ae01
window.inactive.button.pressed.image.color: #ffffff

window.active.button.close.hover.bg: flat solid
window.active.button.close.hover.bg.color: #c01c28
window.active.button.close.hover.image.color: #ffffff

window.inactive.button.close.hover.bg: flat solid
window.inactive.button.close.hover.bg.color: #8b1922
window.inactive.button.close.hover.image.color: #eeeeec

menu.border.width: 1
menu.border.color: #bdbdbd
menu.overlap.x: 0
menu.overlap.y: 0

menu.title.bg: flat solid
menu.title.bg.color: #ebebeb
menu.title.text.color: #1e1e1e

menu.items.bg: flat solid
menu.items.bg.color: #fafafa
menu.items.text.color: #1e1e1e
menu.items.disabled.text.color: #777777

menu.items.active.bg: flat solid
menu.items.active.bg.color: #f2ae01
menu.items.active.text.color: #ffffff

menu.separator.width: 1
menu.separator.padding.width: 4
menu.separator.padding.height: 4
menu.separator.color: #bdbdbd

osd.border.width: 1
osd.border.color: #bdbdbd
osd.label.text.color: #1e1e1e

osd.bg: flat solid
osd.bg.color: #ebebeb
osd.label.bg: parentrelative

osd.hilight.bg: flat solid
osd.hilight.bg.color: #f2ae01
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #d8d8d8
