!# gamebian-installed — Openbox 3 window decorations
!# Modeled on GNOME 45 / libadwaita dark: flat chrome, subtle borders, red close hover.

*.font: shadow=n
window.active.label.text.font: shadow=n
window.inactive.label.text.font: shadow=n
menu.items.font: shadow=n

border.width: 1
padding.width: 4
padding.height: 3
window.handle.width: 2
window.client.padding.width: 0
menu.overlap: 2
*.justify: left

window.active.border.color: #3d3d3d
window.inactive.border.color: #3d3d3d
window.active.client.color: #242424
window.inactive.client.color: #242424

window.active.title.separator.color: #3d3d3d
window.inactive.title.separator.color: #3d3d3d

window.active.label.text.color: #eeeeec
window.inactive.label.text.color: #929292

!# Flat title bar (Adwaita-style unified header)
window.active.title.bg: flat solid
window.active.title.bg.color: #242424
window.active.label.bg: parentrelative
window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #242424
window.inactive.label.bg: parentrelative

!# Resize handles match frame
window.active.handle.bg: flat solid
window.active.handle.bg.color: #242424
window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #242424
window.active.grip.bg: flat solid
window.active.grip.bg.color: #242424
window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #242424

!# Buttons: blend into bar; hover = rounded feel via solid chip (libadwaita ~#3d3d3d)
window.active.button.unpressed.bg: parentrelative
window.active.button.unpressed.image.color: #eeeeec
window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #3d3d3d
window.active.button.hover.image.color: #f6f5f4
window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #303030
window.active.button.pressed.image.color: #c0bfbc
window.active.button.disabled.bg: parentrelative
window.active.button.disabled.image.color: #555555

window.active.button.toggled.unpressed.bg: parentrelative
window.active.button.toggled.unpressed.image.color: #eeeeec
window.active.button.toggled.hover.bg: flat solid
window.active.button.toggled.hover.bg.color: #3d3d3d
window.active.button.toggled.hover.image.color: #f6f5f4
window.active.button.toggled.pressed.bg: flat solid
window.active.button.toggled.pressed.bg.color: #303030
window.active.button.toggled.pressed.image.color: #c0bfbc

window.inactive.button.unpressed.bg: parentrelative
window.inactive.button.unpressed.image.color: #777777
window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #3d3d3d
window.inactive.button.hover.image.color: #c0bfbc
window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #303030
window.inactive.button.pressed.image.color: #929292
window.inactive.button.disabled.bg: parentrelative
window.inactive.button.disabled.image.color: #555555

window.inactive.button.toggled.unpressed.bg: parentrelative
window.inactive.button.toggled.unpressed.image.color: #777777
window.inactive.button.toggled.hover.bg: flat solid
window.inactive.button.toggled.hover.bg.color: #3d3d3d
window.inactive.button.toggled.hover.image.color: #c0bfbc
window.inactive.button.toggled.pressed.bg: flat solid
window.inactive.button.toggled.pressed.bg.color: #303030
window.inactive.button.toggled.pressed.image.color: #929292

!# Close hover — libadwaita destructive / red accent
window.active.button.close.hover.bg: flat solid
window.active.button.close.hover.bg.color: #c01c28
window.active.button.close.hover.image.color: #ffffff

window.inactive.button.close.hover.bg: flat solid
window.inactive.button.close.hover.bg.color: #8b1922
window.inactive.button.close.hover.image.color: #eeeeec

!# Menus (root window / window menu)
menu.border.width: 1
menu.border.color: #3d3d3d
menu.overlap.x: 0
menu.overlap.y: 0

menu.title.bg: flat solid
menu.title.bg.color: #303030
menu.title.text.color: #eeeeec

menu.items.bg: flat solid
menu.items.bg.color: #383838
menu.items.text.color: #eeeeec
menu.items.disabled.text.color: #929292

menu.items.active.bg: flat solid
menu.items.active.bg.color: #3584e4
menu.items.active.text.color: #ffffff
menu.items.active.disabled.text.color: #c0bfbc

menu.separator.width: 1
menu.separator.padding.width: 4
menu.separator.padding.height: 4
menu.separator.color: #3d3d3d

!# OSD (desktop switch, focus cycle)
osd.border.width: 1
osd.border.color: #3d3d3d
osd.label.text.color: #eeeeec

osd.bg: flat solid
osd.bg.color: #242424
osd.label.bg: parentrelative

osd.hilight.bg: flat solid
osd.hilight.bg.color: #3584e4
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #1e1e1e

osd.label.bg: flat solid
osd.label.bg.color: #242424
