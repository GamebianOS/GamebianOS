[Unit]
Description=Gamebian gamepad quick menu
Documentation=file:/etc/gamebian/controller-menu.ini
After=graphical-session-pre.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/local/bin/gamebian-controller-menu
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
