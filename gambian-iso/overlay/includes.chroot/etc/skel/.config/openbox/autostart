# Gamebian Openbox session
# Live ISO: keep blue branding (GTK via Xsession.d; WM theme swaps here).
if grep -qw boot=live /proc/cmdline 2>/dev/null \
	&& grep -q '<name>gamebian-installed</name>' "${HOME}/.config/openbox/rc.xml" 2>/dev/null; then
	sed -i 's|<name>gamebian-installed</name>|<name>gamebian</name>|' "${HOME}/.config/openbox/rc.xml"
	( sleep 0.3 && openbox --reconfigure ) &
fi
# Live ISO: design/*.png shipped to ~/ ; installed disk: monochrome system wallpaper
if grep -qw boot=live /proc/cmdline 2>/dev/null; then
	wall="${HOME}/.local/share/gamebian/background.png"
else
	wall=/usr/share/backgrounds/gamebian-installed/background.png
	if [ ! -r "${wall}" ]; then wall="${HOME}/.local/share/gamebian/background.png"; fi
fi
if [ -r "${wall}" ]; then
	feh --no-fehbg --bg-fill "${wall}" &
fi

# lxpanel layout: same panel config on live ISO vs disk (templates under /usr/share/gamebian/lxpanel/)
mkdir -p "${HOME}/.config/lxpanel/default/panels"
if grep -qw boot=live /proc/cmdline 2>/dev/null; then
	cp -f /usr/share/gamebian/lxpanel/panel-live "${HOME}/.config/lxpanel/default/panels/panel"
else
	cp -f /usr/share/gamebian/lxpanel/panel-installed "${HOME}/.config/lxpanel/default/panels/panel"
fi
lxpanel &

# Rofi: light panel on live ISO; installed disk keeps skel default (gamebian dark theme).
mkdir -p "${HOME}/.config/rofi"
if grep -qw boot=live /proc/cmdline 2>/dev/null; then
	printf '%s\n' '@theme "gamebian-live"' > "${HOME}/.config/rofi/config.rasi"
fi

# PolicyKit UI (must run in the X session before NM secret / control prompts work reliably).
# Trixie+: policykit-1-gnome is gone; mate-polkit / lxpolkit supply agents.
POLKIT_AGENT=""
for _p in /usr/libexec/polkit-gnome-authentication-agent-1 \
	/usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 \
	/usr/libexec/polkit-mate-authentication-agent-1 \
	/usr/bin/lxpolkit; do
	if [ -x "${_p}" ]; then POLKIT_AGENT="${_p}"; break; fi
done
if [ -n "${POLKIT_AGENT}" ]; then
	"${POLKIT_AGENT}" >/dev/null 2>&1 &
fi

# Notification daemon for libnotify / notify-send (Steam first-boot, migration path).
if command -v xfce4-notifyd >/dev/null 2>&1 && ! pgrep -x xfce4-notifyd >/dev/null 2>&1; then
	xfce4-notifyd >/dev/null 2>&1 &
fi

# nm-tray after lxpanel: SystemTray must exist before Qt embeds icons (fixes "No Icon set").
if command -v nm-tray >/dev/null 2>&1 && ! pgrep -x nm-tray >/dev/null 2>&1; then
	(sleep 2; env GTK_ICON_THEME="${GTK_ICON_THEME:-Papirus}" QT_QPA_PLATFORMTHEME=gtk3 QT_AUTO_SCREEN_SCALE_FACTOR=0 QT_IM_MODULE= nm-tray >/dev/null 2>&1) &
fi

# Bluetooth systray (GTK — uses GTK_ICON_THEME=Papirus from Xsession.d like other tray icons).
if command -v blueman-applet >/dev/null 2>&1 && ! pgrep -f '[b]lueman-applet' >/dev/null 2>&1; then
	(sleep 2; env GTK_ICON_THEME="${GTK_ICON_THEME:-Papirus}" blueman-applet >/dev/null 2>&1) &
fi

# Gamepad Guide (or Select+Start) → quick launcher (see /etc/gamebian/controller-menu.ini).
if command -v gamebian-controller-menu >/dev/null 2>&1; then
	if command -v systemctl >/dev/null 2>&1; then
		systemctl --user daemon-reload 2>/dev/null || true
		if systemctl --user start gamebian-controller-menu.service 2>/dev/null; then
			:
		else
			gamebian-controller-menu &
		fi
	else
		gamebian-controller-menu &
	fi
fi

# Installed disk — Steam first-boot (not live): until ~/.config/gamebian-firstboot-steam.done:
# optionally open xfce4-terminal with steam-firstboot-terminal.sh once (Steam install/sign-in, then reboot reminder).
# After first-boot completes, reboot for the fullscreen "Gamebian Steam (gamescope)" session (see LightDM greeter).
if [ -r /usr/share/gamebian/gamebian-steam-login-check.sh ]; then
	# shellcheck source=/usr/share/gamebian/gamebian-steam-login-check.sh
	. /usr/share/gamebian/gamebian-steam-login-check.sh
fi
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games${PATH:+:$PATH}"
STEAM_ONCE="${HOME}/.config/gamebian-firstboot-steam.done"
STEAM_PROMPTED="${HOME}/.config/gamebian-firstboot-steam.prompted"
STEAM_DATA="${XDG_DATA_HOME:-${HOME}/.local/share}/Steam"
if ! grep -qw boot=live /proc/cmdline 2>/dev/null && [ ! -f "${STEAM_ONCE}" ]; then
	if command -v steam >/dev/null 2>&1 && command -v xfce4-terminal >/dev/null 2>&1; then
		has_loginusers=""
		if ( command -v gamebian_have_loginusers_vdf >/dev/null 2>&1 && gamebian_have_loginusers_vdf ); then
			has_loginusers=1
		elif [ -f "${STEAM_DATA}/config/loginusers.vdf" ]; then
			has_loginusers=1
		elif [ -f "${HOME}/.steam/debian-installation/config/loginusers.vdf" ]; then
			has_loginusers=1
		fi
		# Already-logged-in (Valve ~/.local/share/Steam or Debian ~/.steam): enable LightDM gamescope session (NOPASSWD for %sudo).
		if [ "${has_loginusers}" = 1 ] && command -v sudo >/dev/null 2>&1; then
			if sudo -n /usr/sbin/gamebian-enable-steam-lightdm-session 2>/dev/null; then
				mkdir -p "${HOME}/.config" && : > "${STEAM_ONCE}"
				_rbmsg=$'Steam is already set up.\n\nReboot now for the fullscreen Steam session (optimized with gamescope).'
				export DISPLAY="${DISPLAY:-:0}"
				if command -v notify-send >/dev/null 2>&1; then
					DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/bus}" \
						notify-send -a Gamebian -u critical "Please reboot" "${_rbmsg}" 2>/dev/null &
				fi
				if command -v xmessage >/dev/null 2>&1; then
					xmessage -center -buttons OK:0 -default OK "${_rbmsg}" >/dev/null 2>&1 &
				elif command -v zenity >/dev/null 2>&1; then
					zenity --info --no-wrap --title="Gamebian" --text="${_rbmsg}" >/dev/null 2>&1 &
				fi
			fi
		fi
		if [ ! -f "${STEAM_ONCE}" ] && [ ! -f "${STEAM_PROMPTED}" ]; then
			mkdir -p "${HOME}/.config"
			: > "${STEAM_PROMPTED}"
			( sleep 2 && xfce4-terminal \
				--title="Steam setup" \
				-e 'bash /usr/share/gamebian/steam-firstboot-terminal.sh' ) &
		fi
	elif ! command -v steam >/dev/null 2>&1; then
		# No Steam yet — offer install/setup (do not mark first-boot done)
		if [ ! -f "${STEAM_PROMPTED}" ]; then
			mkdir -p "${HOME}/.config"
			: > "${STEAM_PROMPTED}"
			( sleep 2 && xfce4-terminal \
				--title="Install Steam" \
				-e 'bash /usr/share/gamebian/steam-firstboot-terminal.sh' ) &
		fi
	fi
fi

# Calamares only on live session
if grep -qw boot=live /proc/cmdline 2>/dev/null; then
	calamares-install-debian &
fi
