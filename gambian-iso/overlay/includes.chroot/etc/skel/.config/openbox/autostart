# Gamebian Openbox session
if [ -r /usr/share/gamebian/gamebian-session-log.sh ]; then
	# shellcheck source=/usr/share/gamebian/gamebian-session-log.sh
	. /usr/share/gamebian/gamebian-session-log.sh
	gamebian_session_log "openbox-desktop" ""
fi
# Live ISO: keep blue branding (GTK via Xsession.d; WM theme swaps here).
if grep -qw boot=live /proc/cmdline 2>/dev/null \
	&& grep -q '<name>gamebian-installed</name>' "${HOME}/.config/openbox/rc.xml" 2>/dev/null; then
	sed -i 's|<name>gamebian-installed</name>|<name>gamebian</name>|' "${HOME}/.config/openbox/rc.xml"
	( sleep 0.3 && openbox --reconfigure ) &
fi
# Live ISO: design/*.png shipped to ~/ ; installed disk: monochrome system wallpaper
if grep -qw boot=live /proc/cmdline 2>/dev/null; then
	wall="${HOME}/.local/share/gamebian/background.png"
else
	wall=/usr/share/backgrounds/gamebian-installed/background.png
	if [ ! -r "${wall}" ]; then wall="${HOME}/.local/share/gamebian/background.png"; fi
fi
if [ -r "${wall}" ]; then
	feh --no-fehbg --bg-fill "${wall}" &
fi

# Session env for systray (nm-tray / blueman / Steam). Needed on disk installs before lxpanel embeds applets.
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${XDG_RUNTIME_DIR}/bus}"
export GTK_ICON_THEME="${GTK_ICON_THEME:-Papirus}"
export QT_QPA_PLATFORMTHEME="${QT_QPA_PLATFORMTHEME:-gtk3}"
export QT_AUTO_SCREEN_SCALE_FACTOR="${QT_AUTO_SCREEN_SCALE_FACTOR:-0}"

# lxpanel layout: same panel config on live ISO vs disk (templates under /usr/share/gamebian/lxpanel/)
mkdir -p "${HOME}/.config/lxpanel/default/panels"
if grep -qw boot=live /proc/cmdline 2>/dev/null; then
	cp -f /usr/share/gamebian/lxpanel/panel-live "${HOME}/.config/lxpanel/default/panels/panel"
else
	cp -f /usr/share/gamebian/lxpanel/panel-installed "${HOME}/.config/lxpanel/default/panels/panel"
	# Stale lxpanel/systray only when panel was already running (re-login), not every cold boot.
	if pgrep -x lxpanel >/dev/null 2>&1; then
		pkill -x nm-tray 2>/dev/null || true
		pkill -f '[b]lueman-applet' 2>/dev/null || true
		pkill -x lxpanel 2>/dev/null || true
		sleep 0.15
	fi
fi
lxpanel &

# nm-tray + blueman + Steam systray: wait for lxpanel tray plugin (see gamebian-lxpanel-tray.sh).
if [ -x /usr/share/gamebian/gamebian-lxpanel-tray.sh ]; then
	/usr/share/gamebian/gamebian-lxpanel-tray.sh &
fi

# Rofi: light panel on live ISO; installed disk keeps skel default (gamebian dark theme).
mkdir -p "${HOME}/.config/rofi"
if grep -qw boot=live /proc/cmdline 2>/dev/null; then
	printf '%s\n' '@theme "gamebian-live"' > "${HOME}/.config/rofi/config.rasi"
fi

# PolicyKit UI (must run in the X session before NM secret / control prompts work reliably).
# Trixie+: policykit-1-gnome is gone; mate-polkit / lxpolkit supply agents.
POLKIT_AGENT=""
for _p in /usr/libexec/polkit-gnome-authentication-agent-1 \
	/usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 \
	/usr/libexec/polkit-mate-authentication-agent-1 \
	/usr/bin/lxpolkit; do
	if [ -x "${_p}" ]; then POLKIT_AGENT="${_p}"; break; fi
done
if [ -n "${POLKIT_AGENT}" ]; then
	"${POLKIT_AGENT}" >/dev/null 2>&1 &
fi

# Notification daemon (must be up before Steam first-boot / openbox-notify scripts run).
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${XDG_RUNTIME_DIR}/bus}"
if command -v xfce4-notifyd >/dev/null 2>&1 && ! pgrep -x xfce4-notifyd >/dev/null 2>&1; then
	xfce4-notifyd >/dev/null 2>&1 &
	sleep 1
fi
# Queued when notify-send from xfce4-terminal failed (retry with session dbus).
if [ -f "${HOME}/.config/gamebian/pending-openbox-notify" ] \
	&& [ -x /usr/share/gamebian/gamebian-openbox-notify.sh ]; then
	/usr/share/gamebian/gamebian-openbox-notify.sh --no-wait --force &
fi

# Gamepad Guide (or Select+Start) → quick launcher (see /etc/gamebian/controller-menu.ini).
if command -v gamebian-controller-menu >/dev/null 2>&1; then
	if command -v systemctl >/dev/null 2>&1; then
		systemctl --user daemon-reload 2>/dev/null || true
		if systemctl --user start gamebian-controller-menu.service 2>/dev/null; then
			:
		else
			gamebian-controller-menu &
		fi
	else
		gamebian-controller-menu &
	fi
fi

# Installed disk — Steam first-boot (not live): terminal wizard + reboot notice.
if [ -r /usr/share/gamebian/gamebian-steam-ready.sh ]; then
	# shellcheck source=/usr/share/gamebian/gamebian-steam-ready.sh
	. /usr/share/gamebian/gamebian-steam-ready.sh
fi
if [ -r /usr/share/gamebian/gamebian-fix-steam-share.sh ]; then
	# shellcheck source=/usr/share/gamebian/gamebian-fix-steam-share.sh
	. /usr/share/gamebian/gamebian-fix-steam-share.sh
	gamebian_fix_steam_share
fi
if ! grep -qw boot=live /proc/cmdline 2>/dev/null && ! gamebian_firstboot_done; then
	gamebian_on_steam_signed_in
	if ! gamebian_firstboot_done && command -v xfce4-terminal >/dev/null 2>&1 \
		&& [ ! -f "${HOME}/.config/gamebian-firstboot-steam.prompted" ]; then
		mkdir -p "${HOME}/.config"
		: >"${HOME}/.config/gamebian-firstboot-steam.prompted"
		_title="Steam setup"
		command -v steam >/dev/null 2>&1 || _title="Install Steam"
		( sleep 2 && xfce4-terminal \
			--title="${_title}" \
			-e 'bash /usr/share/gamebian/steam-firstboot-terminal.sh' ) &
	fi
fi

if ! grep -qw boot=live /proc/cmdline 2>/dev/null \
	&& [ -x /usr/share/gamebian/gamebian-openbox-notify.sh ]; then
	_notify_args=""
	if gamebian_reboot_notice_eligible 2>/dev/null; then
		_notify_args="--no-wait --force"
	fi
	# shellcheck disable=SC2086
	/usr/share/gamebian/gamebian-openbox-notify.sh ${_notify_args} &
fi
if ! grep -qw boot=live /proc/cmdline 2>/dev/null && ! gamebian_firstboot_done; then
	gamebian_poll_steam_signin_then_notify &
fi

# Calamares only on live session
if grep -qw boot=live /proc/cmdline 2>/dev/null; then
	calamares-install-debian &
fi
