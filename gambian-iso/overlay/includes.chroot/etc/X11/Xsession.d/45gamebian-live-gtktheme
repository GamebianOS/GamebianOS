# GTK theme: live ISO (gamebian) vs installed disk (gamebian-installed), if not already set.
if [ -z "${GTK_THEME:-}" ]; then
    if grep -qw boot=live /proc/cmdline 2>/dev/null; then
        GTK_THEME=gamebian
    else
        GTK_THEME=gamebian-installed
    fi
    export GTK_THEME
fi
# Icon theme: Qt nm-tray uses gtk3 platform theme. Live = Papirus; installed dark GTK = Papirus-Dark.
if [ -z "${GTK_ICON_THEME:-}" ]; then
    if grep -qw boot=live /proc/cmdline 2>/dev/null; then
        GTK_ICON_THEME=Papirus
    else
        GTK_ICON_THEME=Papirus-Dark
    fi
    export GTK_ICON_THEME
fi
