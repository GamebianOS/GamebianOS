# GTK theme: live ISO (gamebian) vs installed disk (gamebian-installed), if not already set.
if [ -z "${GTK_THEME:-}" ]; then
    if grep -qw boot=live /proc/cmdline 2>/dev/null; then
        GTK_THEME=gamebian
    else
        GTK_THEME=gamebian-installed
    fi
    export GTK_THEME
fi
# Icon theme: export for every boot session (not only live). Qt gtk3 platform (nm-tray) uses GtkSettings;
# without this on disk installs, tray icons (e.g. NM, Bluetooth) can render missing / wrong vs live ISO.
if [ -z "${GTK_ICON_THEME:-}" ]; then
    GTK_ICON_THEME=Papirus
    export GTK_ICON_THEME
fi
