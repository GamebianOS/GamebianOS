#!/bin/sh
# LightDM autologin dispatcher: Openbox for first-boot / live, else gamescope kiosk.
# Switch to Desktop only hands off inside the current session (does not change the next boot).

PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games${PATH:+:$PATH}"
export PATH

if grep -qw boot=live /proc/cmdline 2>/dev/null; then
	exec /usr/bin/openbox-session
fi

PREFER="${HOME}/.config/gamebian/prefer-openbox-desktop"
ONCE="${HOME}/.config/gamebian-firstboot-steam.done"

if [ -r /usr/share/gamebian/gamebian-steam-login-check.sh ]; then
	# shellcheck disable=SC1091
	. /usr/share/gamebian/gamebian-steam-login-check.sh
fi

# Explicit “always boot to Openbox” (optional; not set by Switch to Desktop).
if [ -f "${PREFER}" ]; then
	exec /usr/bin/openbox-session
fi

# First-boot: Openbox until Steam setup marker or Valve/Debian loginusers.vdf exists.
if [ ! -f "${ONCE}" ]; then
	_has_login=""
	if command -v gamebian_have_loginusers_vdf >/dev/null 2>&1 && gamebian_have_loginusers_vdf; then
		_has_login=1
	elif [ -f "${HOME}/.local/share/Steam/config/loginusers.vdf" ] \
		|| [ -f "${HOME}/.steam/debian-installation/config/loginusers.vdf" ]; then
		_has_login=1
	fi
	if [ -z "${_has_login}" ]; then
		exec /usr/bin/openbox-session
	fi
fi

exec /usr/local/bin/gamebian-steam-gamescope-session
