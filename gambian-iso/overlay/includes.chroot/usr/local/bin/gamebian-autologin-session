#!/bin/sh
# LightDM autologin dispatcher.
# Live ISO → Openbox. Installed + Steam package → gamescope (not Openbox).
# Desktop only via greeter "Desktop" or ~/.config/gamebian/prefer-openbox-desktop.

PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games${PATH:+:$PATH}"
export PATH

if [ -r /usr/share/gamebian/gamebian-session-log.sh ]; then
	# shellcheck disable=SC1091
	. /usr/share/gamebian/gamebian-session-log.sh
	gamebian_session_log "gamebian-autologin" "$@"
fi

if grep -qw boot=live /proc/cmdline 2>/dev/null; then
	exec /usr/bin/openbox-session
fi

if [ -r /usr/share/gamebian/gamebian-steam-ready.sh ]; then
	# shellcheck disable=SC1091
	. /usr/share/gamebian/gamebian-steam-ready.sh
fi

if [ -f "${HOME}/.config/gamebian/prefer-openbox-desktop" ]; then
	exec /usr/bin/openbox-session
fi

if gamebian_steam_binary_present 2>/dev/null; then
	exec /usr/local/bin/gamebian-steam-gamescope-session
fi

exec /usr/bin/openbox-session
