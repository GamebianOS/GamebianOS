#!/bin/sh
# LightDM Steam session: gamescope + Steam only (no Openbox). Do not fall back when user chose Steam.

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games${PATH:+:$PATH}"

# LightDM sets this before Xsession runs (save before we override).
GAMEBIAN_LIGHTDM_SESSION="${DESKTOP_SESSION:-}"
[ -z "${GAMEBIAN_LIGHTDM_SESSION}" ] && GAMEBIAN_LIGHTDM_SESSION="${GDMSESSION:-}"

if [ -r /usr/share/gamebian/gamebian-session-log.sh ]; then
	# shellcheck disable=SC1091
	. /usr/share/gamebian/gamebian-session-log.sh
	gamebian_session_log "gamebian-steam-gamescope" "ldm=${GAMEBIAN_LIGHTDM_SESSION} $*"
fi

if [ -r /usr/share/gamebian/gamebian-steam-login-check.sh ]; then
	# shellcheck disable=SC1091
	. /usr/share/gamebian/gamebian-steam-login-check.sh
fi
if [ -r /usr/share/gamebian/gamebian-steam-ready.sh ]; then
	# shellcheck disable=SC1091
	. /usr/share/gamebian/gamebian-steam-ready.sh
fi
if [ -r /usr/share/gamebian/gamebian-steam-kiosk-env.sh ]; then
	# shellcheck disable=SC1091
	. /usr/share/gamebian/gamebian-steam-kiosk-env.sh
fi

export GAMEBIAN_GAMESCOPE_SESSION=1
gamebian_kiosk_marker_set 2>/dev/null || true
export DESKTOP_SESSION=gamebian-steam
export XDG_SESSION_DESKTOP=gamebian-steam
export XDG_CURRENT_DESKTOP=gamebian-steam

_uid="$(id -u)"
if [ -z "${XDG_RUNTIME_DIR:-}" ] || [ ! -d "${XDG_RUNTIME_DIR}" ] || [ ! -w "${XDG_RUNTIME_DIR}" ]; then
	export XDG_RUNTIME_DIR="/run/user/${_uid}"
	mkdir -p "${XDG_RUNTIME_DIR}" 2>/dev/null || true
	chmod 700 "${XDG_RUNTIME_DIR}" 2>/dev/null || true
fi

if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
	if [ -S "${XDG_RUNTIME_DIR}/bus" ]; then
		export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"
	elif [ -x /usr/bin/dbus-launch ]; then
		# shellcheck disable=SC2046
		eval $(/usr/bin/dbus-launch --sh-syntax --exit-with-session) 2>/dev/null || true
	fi
fi

POLKIT_AGENT=""
for _p in /usr/libexec/polkit-gnome-authentication-agent-1 \
	/usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 \
	/usr/libexec/polkit-mate-authentication-agent-1 \
	/usr/bin/lxpolkit; do
	if [ -x "${_p}" ]; then
		POLKIT_AGENT="${_p}"
		break
	fi
done
if [ -n "${POLKIT_AGENT}" ]; then
	"${POLKIT_AGENT}" >/dev/null 2>&1 &
fi

if [ -r /etc/default/gamebian-steam-gamescope ]; then
	set -a
	# shellcheck disable=SC1091
	. /etc/default/gamebian-steam-gamescope
	set +a
fi
if [ -r "${HOME}/.config/gamebian/steam-gamescope.env" ]; then
	set -a
	# shellcheck disable=SC1091
	. "${HOME}/.config/gamebian/steam-gamescope.env"
	set +a
fi

_force_steam=0
case "${GAMEBIAN_LIGHTDM_SESSION}" in
	gamebian-steam|gamebian-steam-gamescope) _force_steam=1 ;;
esac

_log="${XDG_CACHE_HOME:-${HOME}/.cache}/gamebian/session.log"
mkdir -p "$(dirname "$_log")" 2>/dev/null || true

if ! grep -qw boot=live /proc/cmdline 2>/dev/null; then
	_have_steam=0
	gamebian_steam_binary_present 2>/dev/null && _have_steam=1
	_kiosk_ok=0
	gamebian_steam_kiosk_ready 2>/dev/null && _kiosk_ok=1

	if [ "${_have_steam}" -eq 0 ]; then
		printf '%s gamescope-session: no steam binary, fallback openbox\n' \
			"$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date)" >>"$_log" 2>/dev/null || true
		exec /usr/bin/openbox-session
	fi

	if [ "${_kiosk_ok}" -eq 0 ] && [ "${_force_steam}" -eq 0 ]; then
		printf '%s gamescope-session: kiosk not ready, fallback openbox (ldm=%s)\n' \
			"$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date)" "${GAMEBIAN_LIGHTDM_SESSION}" >>"$_log" 2>/dev/null || true
		export DISPLAY="${DISPLAY:-:0}"
		touch "${HOME}/.config/gamebian/pending-openbox-notify" 2>/dev/null || true
		exec /usr/bin/openbox-session
	fi

	if [ "${_kiosk_ok}" -eq 0 ] && [ "${_force_steam}" -eq 1 ]; then
		printf '%s gamescope-session: forcing kiosk (ldm=%s kiosk_ok=0)\n' \
			"$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date)" "${GAMEBIAN_LIGHTDM_SESSION}" >>"$_log" 2>/dev/null || true
	fi
fi

if gamebian_use_steam_without_gamescope 2>/dev/null; then
	printf '%s gamescope-session: no working gamescope — Steam on X (GAMEBIAN_SKIP_GAMESCOPE)\n' \
		"$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date)" >>"$_log" 2>/dev/null || true
	export GAMEBIAN_SKIP_GAMESCOPE=1
else
	printf '%s gamescope-session: starting kiosk (ldm=%s force=%s)\n' \
		"$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date)" "${GAMEBIAN_LIGHTDM_SESSION}" "${_force_steam}" >>"$_log" 2>/dev/null || true
fi

/usr/local/bin/gamebian-steam-bigpicture "$@"
_rc=$?

if [ -f "${GAMEBIAN_SWITCH_OPENBOX:-${HOME}/.config/gamebian/switch-to-openbox}" ]; then
	rm -f "${GAMEBIAN_SWITCH_OPENBOX}" 2>/dev/null || true
	gamebian_kiosk_marker_clear 2>/dev/null || true
	exec /usr/bin/openbox-session
fi

gamebian_kiosk_marker_clear 2>/dev/null || true
exit "${_rc}"
