# Solid black panel (disk install — gamebian-installed look)
Global {
    edge=bottom
    align=left
    margin=0
    widthtype=percent
    width=100
    height=30
    transparent=0
    setdocktype=1
    setpartialstrut=1
    usefontcolor=1
    fontcolor=#ffffff
    background=0
}

Plugin {
    type = launchbar
    Config {
        Button {
            id=gamebian-menu.desktop
        }
    }
}

Plugin {
    type = space
    Config {
        Size=4
    }
}

Plugin {
    type = taskbar
    expand=1
    Config {
        tooltips=1
        IconsOnly=0
        AcceptSkipPager=1
        ShowIconified=1
        ShowMapped=1
        ShowAllDesks=0
        ShowSquareBrackets=0
        UseMouseWheel=1
        UseUrgencyHint=1
        FlatButton=0
        MaxTaskWidth=150
        spacing=1
    }
}

Plugin {
    type = space
    Config {
        Size=4
    }
}

Plugin {
    type = tray
}

Plugin {
    type = dclock
    Config {
        ClockFmt=%I:%M %p
        TooltipFmt=%A %d %B
        BoldFont=0
    }
}
